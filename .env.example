# Runtime profile
APP_ENV=development

# Comma-separated list for browser clients. In production set your real domain(s).
ALLOW_ORIGINS=http://127.0.0.1:8011,http://localhost:8011

# Set to true only when you explicitly need credentialed CORS requests.
ALLOW_CREDENTIALS=false

# Comma-separated hosts accepted in Host header (use domain names in production).
TRUSTED_HOSTS=localhost,127.0.0.1

# Cap concurrent active environments kept in memory.
MAX_ACTIVE_ENVS=128
